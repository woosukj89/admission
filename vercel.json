{
  "version": 2,
  "outputDirectory": "frontend",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/api/index" },
    { "source": "/auth/:path*",      "destination": "/api/index" },
    { "source": "/recommend:path*",  "destination": "/api/index" },
    { "source": "/stats:path*",      "destination": "/api/index" }
  ]
}
