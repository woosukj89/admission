# Google OAuth2 credentials (for user login/identity only — NOT for Gemini API)
# Create at: Google Cloud Console → APIs & Services → Credentials → OAuth2 Web App
# Authorized redirect URI must be: {APP_BASE_URL}/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT session signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Base URL for OAuth callback (change for production)
APP_BASE_URL=http://localhost:8000

# Anthropic API key (for hybrid mode: Haiku tool calls + Sonnet fallback)
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Vercel Edge Config connection string (enables hybrid AI mode)
# Get at: Vercel dashboard → Storage → Edge Config → Connection string
# Set key "anthropic_enabled" = true in Edge Config to activate hybrid mode
# Leave empty to use Gemini-only mode (default for local dev)
EDGE_CONFIG=

# Gemini API key (for free tier users)
# Get at: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1,500 RPD (gemini-2.0-flash)
GEMINI_API_KEY=

# Toss Payments (web subscriptions — 8,000 KRW/month)
# Get at: https://developers.tosspayments.com/
# Use test keys (prefix "test_") during development
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Webhook secret — set in Toss dashboard to secure webhook endpoint
TOSS_WEBHOOK_SECRET=

# RevenueCat (mobile in-app purchases)
# Get at: https://app.revenuecat.com/
# Set this to your RevenueCat webhook authorization header value
REVENUECAT_WEBHOOK_SECRET=

# Google AdSense (web rewarded ads — free tier users earn extra questions)
# Get at: https://adsense.google.com → My ads → Ad units → Rewarded ad
# Publisher ID format: ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_PUB_ID=
# Rewarded ad unit slot ID (numbers only, e.g. 1234567890)
ADSENSE_REWARDED_SLOT=

# ── Beta / Feature Flags ──────────────────────────────────────────────────────
# Set to "false" during beta to hide all payment/subscription UI
PAYMENTS_ENABLED=false

# ── Email (for email+password signup verification codes) ──────────────────────
# Use any SMTP provider (Gmail, SendGrid, Mailgun, etc.)
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use App Password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Secret for GET /api/admin/stats endpoint (leave empty to allow all)
ADMIN_SECRET=

# ── Cloud Database (Supabase / PostgreSQL) ────────────────────────────────────
# Leave empty to use local SQLite (data/users.db).
# Set to Supabase connection string for production deployment.
# Get at: supabase.com → Project → Settings → Database → Connection string (URI)
DATABASE_URL=
